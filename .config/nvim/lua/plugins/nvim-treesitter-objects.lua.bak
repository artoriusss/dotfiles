return {
  {
    "romus204/tree-sitter-manager.nvim",
    config = function()
      require("tree-sitter-manager").setup({
        ensure_installed = { "lua", "python", "markdown", "markdown_inline", "vim", "bash", "json", "yaml" },
      })
    end,
  },
  {
    "nvim-treesitter/nvim-treesitter-textobjects",
    -- CRITICAL: Prevent the plugin from running its own internal startup logic
    -- This stops the error about 'nvim-treesitter.configs' being missing
    enabled = true,
    event = "VeryLazy",
    config = function()
        -- Intentionally empty: We don't want the plugin's code to run
    end,
    -- Manually add the queries to the runtime path so mini.ai sees them
    init = function()
        local data_path = vim.fn.stdpath("data")
        vim.opt.runtimepath:append(data_path .. "/lazy/nvim-treesitter-textobjects")
    end
  },
}
