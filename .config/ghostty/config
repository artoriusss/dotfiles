theme = BlueBerryPie
font-size = 16
font-family = "Maple Mono NF"
cursor-style = block
cursor-style-blink = true

keybind = ctrl+page_up=unbind
keybind = ctrl+page_down=unbind
keybind = ctrl+enter=unbind

# Free ctrl+shift+n/e/i/o for Neovim split navigation (n/e/i/o = left/down/up/right)
keybind = ctrl+shift+n=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+i=unbind
keybind = ctrl+shift+o=unbind
# Move new_window off ctrl+shift+n onto ctrl+shift+t (drops the unused new_tab)
keybind = ctrl+shift+t=new_window

window-decoration = none

scrollback-limit = 10000000

# window padding pain
window-padding-x = 0
window-padding-y = 0
adjust-cell-height = 1%
window-padding-color = extend

